# ──────────────────────────────────────────────
# Backend (Render) — Required
# ──────────────────────────────────────────────

# Groq API key — set both (used by different layers of the app)
GROQ_API_KEY=your_groq_api_key_here
M1_GROQ_API_KEY=your_groq_api_key_here

# The deployed Vercel frontend URL (set after frontend deploys)
FRONTEND_URL=https://your-project.vercel.app

# HuggingFace cache (auto-set in Dockerfile/render.yaml — do not override)
# HF_HOME=/tmp/hf_cache

# ──────────────────────────────────────────────
# Frontend (Vercel) — Required
# ──────────────────────────────────────────────

# The deployed Render backend URL (set after backend deploys)
NEXT_PUBLIC_API_URL=https://your-project.onrender.com
