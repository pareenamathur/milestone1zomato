# Copy this file to .env and adjust as needed.

# Dataset
M1_DATASET_ID=ManikaSaini/zomato-restaurant-recommendation

# Caching
M1_CACHE_DIR=.cache
M1_CLEANED_DATA_PATH=.cache/cleaned_restaurants.parquet

# Sizing
M1_TOP_K_CANDIDATES=50
M1_TOP_K_RECOMMENDATIONS=10

# Defaults
M1_DEFAULT_MIN_RATING=3.5

# Budget behavior
M1_BUDGET_MODE=category
M1_BUDGET_LOW_MAX=300
M1_BUDGET_MEDIUM_MAX=700

# LLM (placeholders for Phase 0)
M1_LLM_PROVIDER=openai
M1_LLM_MODEL=gpt-4.1-mini
M1_LLM_TEMPERATURE=0.2
M1_LLM_TIMEOUT_S=30

